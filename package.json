{
  "name": "fromlan-pi-hub",
  "version": "0.9.0",
  "description": "Fromlan Pi Hub — 本地 pi Agent 工位台：Kanban 派活、Squad、Autopilot、Inbox",
  "author": "Fromlan",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "node scripts/dist.mjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "cronstrue": "^3.24.0",
    "highlight.js": "^11.10.0",
    "lucide-react": "^1.24.0",
    "node-cron": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "dev.fromlan.pi-hub",
    "productName": "Fromlan Pi Hub",
    "executableName": "Fromlan Pi Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Fromlan-Pi-Hub-portable-${arch}.exe"
    }
  }
}
